      <!-- 1 thread, ramp 1s, 1 loop -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="[TEST] Stress - ${__P(threads,1)}u Ramp${__P(rampup,1)}s Loop${__P(loops,1)}" enabled="true">
