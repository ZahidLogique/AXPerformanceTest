        <!-- ═══════════════════════════════════════════════════════════ -->
        <!--  PHASE 2: WebSocket Bidding Flow                           -->
        <!--  Referensi: Curl websocket Customer bid.txt                -->
        <!--  Event: 42["customer-bidding", {headers, payload}]         -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- STEP 2a: Get current auction state — ambil last bid ID dan harga terkini -->
        <!-- Entry pertama di response = bid terbaru untuk lot ini                    -->
        <!-- Extract: CURRENT_PRICE (last_price[0]) dan PARENT_BID_ID (_id[0])       -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="2a. GET Current Auction State (History Bid)" enabled="true">
          <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/auction/customer-history-bid</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
            <collectionProp name="Arguments.arguments">
              <elementProp name="auction_id" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_id</stringProp>
                <stringProp name="Argument.value">${AUCTION_ID}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
              <elementProp name="inventory_id" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">inventory_id</stringProp>
                <stringProp name="Argument.value">${INVENTORY_ID}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
              <elementProp name="auction_lane" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_lane</stringProp>
                <stringProp name="Argument.value">${AUCTION_LANE}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
              <elementProp name="auction_lot" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_lot</stringProp>
                <stringProp name="Argument.value">${AUCTION_LOT}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Parse JSON response, ambil entry pertama untuk lot 1018             -->
          <!-- Extract: PARENT_BID_ID (_id[0] - 2) dan CURRENT_PRICE (last_price[0]) -->
          <!-- Pattern: WS _id = history _id - 2 (confirmed dari semua data WS)   -->
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract &amp; Adjust bid state from History JSON" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def responseBody = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(responseBody)
def data = json.data

// Cari entry pertama dengan last_price != null (skip Separator entries)
def firstBid = data.find { it.last_price != null &amp;&amp; it.last_price instanceof Number }

if (firstBid) {
    def historyId = firstBid._id as String
    def currentPrice = firstBid.last_price as int

    // WS record _id = history _id - 2 (last byte hex)
    def prefix = historyId.substring(0, 22)
    def lastByte = Integer.parseInt(historyId.substring(22, 24), 16)
    def wsId = prefix + String.format("%02x", lastByte - 2)

    vars.put("PARENT_BID_ID", wsId)
    vars.put("CURRENT_PRICE", currentPrice.toString())

    log.info("=== Auction State ===")
    log.info("First bid entry - lot: " + firstBid.auction_lot + " | last_price: " + currentPrice + " | _id: " + historyId)
    log.info("PARENT_BID_ID (adjusted): " + historyId + " -> " + wsId)
    log.info("CURRENT_PRICE: " + currentPrice)
    log.info("BID_PRICE (current + 5000): " + (currentPrice + 5000))
} else {
    log.warn("Tidak ada entry bid valid di history response!")
    vars.put("PARENT_BID_ID", "PARENT_BID_ID_NOT_FOUND")
    vars.put("CURRENT_PRICE", "0")
}
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

