          <stringProp name="path"></stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">5000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree/>

        <!-- STEP 2l: Broadcast 2 — bidding info broadcast                    -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2l. WebSocket Read - Broadcast 2 (bidding)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">5000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree/>

        <!-- STEP 2m: Broadcast 3 — bid-unlock                                -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2m. WebSocket Read - Broadcast 3 (bid-unlock)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">5000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree/>

        <!-- STEP 2n: Baca ACK bid — 433[{status:true, info:{...}}]           -->
        <!-- Pesan ke-4 dari server = ack untuk 423["customer-bidding"]       -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2n. WebSocket Read - Bid ACK (433)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="connectTimeout">20000</stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">8000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree>
          <!-- Cek ack mengandung status:true sebagai tanda bid berhasil       -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert Bid ACK - status:true" enabled="false">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">status&quot;:true</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Bid ACK tidak mengandung status:true — kemungkinan bid gagal atau server kirim urutan pesan berbeda</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">true</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- STEP 2o: Baca countdown broadcast dari server                     -->
        <!-- Server kirim setelah bid berhasil: 42["countdown",{...}]        -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2o. WebSocket Read - Countdown broadcast" enabled="true">
          <boolProp name="TLS">false</boolProp>
