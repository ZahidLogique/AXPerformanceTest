        <hashTree>
          <!-- DISABLED: WS namespace confirm (40{...}) tidak pernah mengandung next_price -->
          <!-- Regex tidak pernah match → default=125000 selalu override CURRENT_PRICE   -->
          <!-- yang sudah benar di-set oleh JSR223 step 2a. Jadi extractor ini dimatikan. -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract CURRENT_PRICE (next_price) from WS - DISABLED" enabled="false">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
            <stringProp name="RegexExtractor.refname">CURRENT_PRICE</stringProp>
            <stringProp name="RegexExtractor.regex">&quot;next_price&quot;\s*:\s*(\d+)</stringProp>
