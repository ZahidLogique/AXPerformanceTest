          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor" testname="Extract PARENT_BID_ID (_id) from WS - DISABLED" enabled="false">
            <stringProp name="RegexExtractor.useHeaders">false</stringProp>
