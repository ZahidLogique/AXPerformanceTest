        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!--  STEP 2g: Check Latest — ambil state bid terkini via WS           -->
        <!--  Response berisi _id (langsung = parent_bid_id) dan last_price    -->
        <!--  Ack ID=2: 422["check-latest", {headers, payload}]                -->
        <!--  Menggantikan HTTP bidding-validation + -2 hack                   -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleWriteWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler" testname="2g. WebSocket Write - Check Latest (422)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="dataType">Text</stringProp>
          <stringProp name="requestData">422["check-latest",{"headers":{"headers":{"Authorization":"Bearer ${TOKEN}","lang":"en"}},"payload":{"auction_id":"${AUCTION_ID}","auction_lane":"${AUCTION_LANE}","auction_lot":"${AUCTION_LOT}","inventory_id":"${INVENTORY_ID}"}}]</stringProp>
        </eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler>
        <hashTree/>

        <!-- STEP 2h: Baca response check-latest                               -->
        <!-- Server kirim: 432[{"status":true,"data":{"_id":"...","last_price":145000,"next_price":147000,...}}] -->
        <!-- Extract: PARENT_BID_ID = _id (langsung, tanpa -2!)                -->
        <!--          CURRENT_PRICE = last_price (harga saat ini)              -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2h. WebSocket Read - Check Latest Response (432)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="connectTimeout">20000</stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">8000</stringProp>
          <boolProp name="optional">false</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree>
          <!-- Extract _id → PARENT_BID_ID (direct, no -2 adjustment)         -->
          <!-- Extract last_price → CURRENT_PRICE                              -->
          <!-- Ini adalah sumber data paling akurat untuk bid                  -->
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract bid state from check-latest (authoritative)" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def body = prev.getResponseDataAsString()
log.info("=== check-latest Response ===")
log.info(body)

// Jika bukan ACK 432 (misal broadcast bid-lock/bidding/thepong dari user lain), skip parsing
// Tetap pakai PARENT_BID_ID &amp; CURRENT_PRICE dari nilai sebelumnya
if (!body.startsWith("432")) {
    log.warn("check-latest: dapat non-ACK message, skip parsing. body=" + body.take(80))
    return
}

// Format: 432[{"status":true,"data":{...},"info":{...}}]
def jsonStr = body.replaceFirst('^\\d+', '')
def arr = new JsonSlurper().parseText(jsonStr)
def obj = arr[0]

if (!(obj instanceof Map) || obj?.data == null) {
    log.warn("check-latest: format tidak dikenali atau data null! body=" + body)
    return
}

def data = obj.data
def eventId   = data._id as String
def lastPrice = data.last_price as int
def nextPrice = data.next_price

// PARENT_BID_ID = _id dari check-latest (langsung, tanpa adjustment -2)
vars.put("PARENT_BID_ID", eventId)

// CURRENT_PRICE = last_price (harga auction saat ini)
vars.put("CURRENT_PRICE", lastPrice.toString())

log.info("=== Bid state dari check-latest ===")
log.info("PARENT_BID_ID: " + eventId)
log.info("CURRENT_PRICE: " + lastPrice)
log.info("next_price (info): " + nextPrice)
log.info("last_price bid akan dikirim: " + (lastPrice + (vars.get("INCREMENT") as int)))
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- STEP 2h1: Kirim theping setelah check-latest — sebelum bid         -->
        <!-- Referensi HAR: dikirim tepat setelah check-latest response        -->
        <eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleWriteWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler" testname="2h1. WebSocket Write - theping (before bid)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="dataType">Text</stringProp>
          <stringProp name="requestData">42["theping",{"date":${__time()}}]</stringProp>
        </eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler>
        <hashTree/>

        <!-- STEP 2h2: Baca thepong dari server                                -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2h2. WebSocket Read - thepong (before bid)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">5000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree/>

        <!-- STEP 2i: HTTP Bidding Validation — DISABLED                       -->
        <!-- Digantikan oleh WS check-latest (step 2g-2h) yang lebih akurat   -->
        <!-- _id dari check-latest langsung = parent_bid_id, tanpa -2 hack    -->
        <!-- Validasi hak bid tetap berjalan di server saat bid dikirim        -->
        <!-- STEP 2i: Validasi hak bid + extract parent_bid_id dari last event -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="2i. GET Bidding Validation" enabled="true">
          <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/auction/bidding-validation</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
            <collectionProp name="Arguments.arguments">
              <elementProp name="auction_id" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_id</stringProp>
                <stringProp name="Argument.value">${AUCTION_ID}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
              <elementProp name="auction_lane" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_lane</stringProp>
                <stringProp name="Argument.value">${AUCTION_LANE}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
              <elementProp name="auction_lot" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_lot</stringProp>
                <stringProp name="Argument.value">${AUCTION_LOT}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert Bidding Validation - HTTP 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Bidding Validation GAGAL - token expired atau user tidak berhak bid</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <!-- Extract _id dari bidding-validation (= last event: bid atau conductor)  -->
          <!-- OVERRIDE parent_bid_id dengan last event _id - 2                       -->
          <!-- Karena parent_bid_id mengikuti chain event terakhir, bukan hanya bid   -->
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Override PARENT_BID_ID from Bidding Validation" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def responseBody = prev.getResponseDataAsString()
log.info("=== Bidding Validation Response ===")
log.info(responseBody)

def json = new JsonSlurper().parseText(responseBody)
def data = json.data

// ── PARENT_BID_ID sudah di-set dengan benar oleh check-latest (step 2h) ───
// TIDAK di-override di sini — override sebelumnya menyebabkan hex underflow bug
// (lastByte - 2 ketika lastByte=01 → -1 → "ffffffff", id invalid 28 char)

// ── Override CURRENT_PRICE dari next_price (server authoritative) ──────────
// next_price = harga yang harus ada di current_price saat kita bid
// last_price dalam bid = next_price + increment (harga bid kita)
def nextPrice = data?.next_price
if (nextPrice != null &amp;&amp; nextPrice instanceof Number &amp;&amp; (nextPrice as int) &gt; 0) {
    vars.put("CURRENT_PRICE", (nextPrice as int).toString())
    log.info("CURRENT_PRICE overridden by next_price: " + nextPrice)
} else {
    // Fallback: CURRENT_PRICE sudah di-set dari check-latest (last_price)
    log.info("next_price tidak tersedia, CURRENT_PRICE tetap dari check-latest: " + vars.get("CURRENT_PRICE"))
}

log.info("=== Bid akan dikirim dengan ===")
log.info("current_price: " + vars.get("CURRENT_PRICE"))
def cp = vars.get("CURRENT_PRICE") as int
def inc = vars.get("INCREMENT") as int
log.info("last_price (bid): " + (cp + inc))
log.info("parent_bid_id: " + vars.get("PARENT_BID_ID"))
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- STEP 2i-fresh: HTTP GET history-bid sesaat sebelum bid              -->
        <!-- Tujuan: refresh CURRENT_PRICE agar tidak stale karena concurrent  -->
        <!-- PARENT_BID_ID tetap dari step 2h (check-latest WS)               -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="2i-fresh. GET Fresh Price (pre-bid)" enabled="true">
          <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/auction/customer-history-bid</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.postBodyRaw">false</boolProp>
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
            <collectionProp name="Arguments.arguments">
              <elementProp name="auction_id" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_id</stringProp>
                <stringProp name="Argument.value">${AUCTION_ID}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
              <elementProp name="inventory_id" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">inventory_id</stringProp>
                <stringProp name="Argument.value">${INVENTORY_ID}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
              <elementProp name="auction_lane" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_lane</stringProp>
                <stringProp name="Argument.value">${AUCTION_LANE}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
              <elementProp name="auction_lot" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.name">auction_lot</stringProp>
                <stringProp name="Argument.value">${AUCTION_LOT}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
              </elementProp>
            </collectionProp>
          </elementProp>
        </HTTPSamplerProxy>
        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Refresh CURRENT_PRICE from fresh history-bid" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def responseBody = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(responseBody)
def data = json.data

def firstBid = data.find { it.last_price != null &amp;&amp; it.last_price instanceof Number }

if (firstBid) {
    def freshPrice = firstBid.last_price as int
    def oldPrice = vars.get("CURRENT_PRICE")
    vars.put("CURRENT_PRICE", freshPrice.toString())
    log.info("=== Fresh Price (pre-bid) ===")
    log.info("CURRENT_PRICE updated: " + oldPrice + " -> " + freshPrice)
    log.info("BID akan dikirim: " + (freshPrice + (vars.get("INCREMENT") as int)))
} else {
    log.warn("2i-fresh: tidak ada entry valid, CURRENT_PRICE tetap: " + vars.get("CURRENT_PRICE"))
}
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!--  STEP 2j: Kirim bid via WebSocket                                 -->
        <!--  Ack ID=3: 423["customer-bidding", {headers, payload}]            -->
        <!--  current_price = last_price dari check-latest (harga saat ini)   -->
        <!--  last_price    = current_price + increment (harga bid kita)       -->
        <!--  parent_bid_id = _id dari check-latest (langsung, tanpa -2)      -->
        <!--  Referensi HAR: >>> SEND 423["customer-bidding",{...}]            -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleWriteWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler" testname="2j. WebSocket Write - Customer Bid (423)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="dataType">Text</stringProp>
          <stringProp name="requestData">423["customer-bidding",{"headers":{"headers":{"Authorization":"Bearer ${TOKEN}","lang":"en"}},"payload":{"auction_id":"${AUCTION_ID}","auction_lane":"${AUCTION_LANE}","room_id":"${ROOM_ID}","auction_lot":"${AUCTION_LOT}","bidtype":"web","nipl":"${NIPL}","increment":${INCREMENT},"reserved_price":0,"inventory_id":"${INVENTORY_ID}","current_price":${CURRENT_PRICE},"last_price":${__intSum(${CURRENT_PRICE},${INCREMENT},)},"parent_bid_id":"${PARENT_BID_ID}","seller_id":"${SELLER_ID}"}}]</stringProp>
        </eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler>
        <hashTree/>

        <!-- Server kirim 4-5 pesan berturut setelah bid:                      -->
        <!-- 1. 42["bid-lock",{...}]     — broadcast: bidding terkunci        -->
        <!-- 2. 42["bidding",{...}]      — broadcast: info bid terbaru        -->
        <!-- 3. 42["bid-unlock",{...}]   — broadcast: bidding dibuka lagi     -->
        <!-- 4. 433[{status:true,...}]   — ACK bid kita (mengandung status)   -->
        <!-- 5. 42["countdown",{...}]    — broadcast: countdown timer         -->

        <!-- STEP 2k: Broadcast 1 — bid-lock (optional, bisa datang duluan)   -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2k. WebSocket Read - Broadcast 1 (bid-lock)" enabled="true">
