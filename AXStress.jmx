          <stringProp name="readTimeout">5000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree/>

        <!-- STEP 2p: Tutup koneksi WebSocket                                  -->
        <!-- DISABLED: server sudah nutup koneksi duluan setelah countdown    -->
        <!-- CloseWebSocketSampler tidak support optional, jadi di-disable    -->
        <eu.luminis.jmeter.wssampler.CloseWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.CloseWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.CloseWebSocketSampler" testname="2o. WebSocket Close Connection (DISABLED - server closes first)" enabled="false">
          <boolProp name="createNewConnection">false</boolProp>
        </eu.luminis.jmeter.wssampler.CloseWebSocketSampler>
        <hashTree/>

