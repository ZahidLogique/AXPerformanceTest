//backoffice.ax-stg.lgq-stg.com/dist/js/adminlte.js\"></script>\n    <script src=\"https://backoffice.ax-stg.lgq-stg.com/plugins/select2/js/select2.full.min.js\"></script>\n    <script src=\"https://backoffice.ax-stg.lgq-stg.com/plugins/summernote/summernote-bs4.min.js\"></script>\n    <script src=\"https://backoffice.ax-stg.lgq-stg.com/plugins/flatpickr/flatpickr.min.js\"></script>\n    <script src=\"https://backoffice.ax-stg.lgq-stg.com/plugins/sweetalert2/sweetalert2.min.js\"></script>\n    <script src=\"https://backoffice.ax-stg.lgq-stg.com/plugins/toastr/toastr.min.js\"></script>\n    <script src=\"https://backoffice.ax-stg.lgq-stg.com/plugins/hammer/hammer.min.js\"></script>\n    <script>\n        var pikadayI18n = {\n            en: {\n                previousMonth: 'Previous Month',\n                nextMonth: 'Next Month',\n                months: ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September',\n                    'October', 'November', 'December'\n                ],\n                weekdays: ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],\n                weekdaysShort: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat']\n            },\n            th: {\n                previousMonth: 'เดือนก่อนหน้า',\n                nextMonth: 'เดือนถัดไป',\n                months: ['มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน', 'กรกฎาคม', 'สิงหาคม',\n                    'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'\n                ],\n                weekdays: ['วันอาทิตย์', 'วันจันทร์', 'วันอังคาร', 'วันพุธ', 'วันพฤหัสบดี', 'วันศุกร์', 'วันเสาร์'],\n                weekdaysShort: ['อา', 'จ', 'อ', 'พ', 'พฤ', 'ศ', 'ส']\n            }\n        }\n        var datepickers = document.querySelectorAll(\".datepicker\");\n        var picker = [];\n        var nowYear = new Date().getFullYear();\n        var maxyear = nowYear + 334;\n\n        for (var i = 0; i < datepickers.length; i++) {\n            let prop = {\n                field: datepickers[i],\n                //format: 'YYYY-MM-DD'\n                format: 'DD/MM/YYYY',\n                yearRange: [1968, maxyear],\n            }\n\n            let datepicker = $(datepickers[i]);\n            if (datepicker.hasClass('datepicker-min-today')) {\n                prop.minDate = new Date()\n            }\n\n            picker[i] = new Pikaday(prop)\n        }\n\n        const datepickerMonths = document.querySelectorAll('.datepicker-month');\n        var pickersMonth = [];\n        for (var j = 0; j < datepickerMonths.length; j++) {\n            let prop = {\n                field: datepickerMonths[j],\n                format: 'MM/YYYY'\n            }\n            pickersMonth[j] = new Pikaday(prop)\n        }\n\n        $(document).ready(function() {\n            //load call\n            $(\".select2\").select2({\n                theme: 'bootstrap4',\n            });\n\n            //waiting emit call\n            window.livewire.on('loadSelect2', () => {\n                $(\".select2\").select2({\n                    theme: 'bootstrap4',\n                });\n            });\n\n            window.livewire.on('loadDatepicker', () => {\n                var datepickers = document.querySelectorAll(\".datepicker\");\n                // var picker = [];\n                $.each(picker, function(k, v) {\n                    v.destroy();\n                });\n                var nowYear = new Date().getFullYear();\n                var maxyear = nowYear + 5;\n\n                for (var i = 0; i < datepickers.length; i++) {\n                    let prop = {\n                        field: datepickers[i],\n                        //format: 'YYYY-MM-DD'\n                        format: 'DD/MM/YYYY',\n                        yearRange: [1968, maxyear],\n                    }\n\n                    let datepicker = $(datepickers[i]);\n                    if (datepicker.hasClass('datepicker-min-today')) {\n                        prop.minDate = new Date()\n                        console.log(prop);\n                    }\n\n                    picker[i] = new Pikaday(prop)\n                }\n            });\n\n            window.addEventListener('loadDatepicker', event => {\n                if (event.detail.id) {\n                    var datepickers = $(\"#\" + event.detail.id + \" .datepicker\");\n                    $.each(picker, function(k, v) {\n                        if ($(v._o.field).closest('#' + event.detail.id).length) {\n                            v.destroy();\n                        }\n                    });\n                } else {\n                    var datepickers = document.querySelectorAll(\".datepicker\");\n                    $.each(picker, function(k, v) {\n                        v.destroy();\n                    });\n                }\n                var nowYear = new Date().getFullYear();\n                var maxyear = nowYear + 5;\n\n                for (var i = 0; i < datepickers.length; i++) {\n                    let prop = {\n                        field: datepickers[i],\n                        //format: 'YYYY-MM-DD'\n                        format: 'DD/MM/YYYY',\n                        yearRange: [1968, maxyear],\n                    }\n\n                    let datepicker = $(datepickers[i]);\n                    if (datepicker.hasClass('datepicker-min-today')) {\n                        prop.minDate = new Date()\n                        console.log(prop);\n                    }\n\n                    picker[i] = new Pikaday(prop)\n                }\n            })\n\n            window.addEventListener('swalError', event => {\n                Swal.fire({\n                    icon: 'error',\n                    title: 'Error',\n                    text: event.detail.messages\n                })\n            })\n\n            window.addEventListener('loadCurrencyMasking', event => {\n                $('.input-currency').mask(\"#,##0\", {\n                    reverse: true\n                });\n            })\n\n            $(\".upper_text\").keyup(function() {\n                var valtext = $(this).val()\n                $(this).val(valtext.toUpperCase())\n            });\n\n            $(\".timepicker\").flatpickr({\n                enableTime: true,\n                noCalendar: true,\n                dateFormat: \"H:i\",\n                time_24hr: true\n            });\n        });\n\n        function numberToCurrency(a) {\n            if (a != '' && a != null) {\n                a = a.toString();\n                var b = a.replace(/[^\\d\\.]/g, '');\n                var dump = b.split('.');\n                var c = '';\n                var lengthchar = dump[0].length;\n                var j = 0;\n                for (var i = lengthchar; i > 0; i--) {\n                    j = j + 1;\n                    if (((j % 3) == 1) && (j != 1)) {\n                        c = dump[0].substr(i - 1, 1) + ',' + c;\n                    } else {\n                        c = dump[0].substr(i - 1, 1) + c;\n                    }\n                }\n\n                if (dump.length > 1) {\n                    if (dump[1].length > 0) {\n                        c += '.' + dump[1];\n                    } else {\n                        c += '.';\n                    }\n                }\n                return c;\n            } else {\n                return '';\n            }\n        }\n\n        $(document).ready(function() {\n            window.livewire.on('alert_remove', () => {\n                setTimeout(function() {\n                    $('.alert-success').fadeOut('fast');\n                }, 5000); // 5 secs\n            });\n\n            /** add active class and stay opened when selected */\n            var url = window.location;\n\n            // for sidebar menu entirely but not cover treeview\n            $('ul.nav-sidebar a').filter(function() {\n                return this.href == url;\n            }).addClass('active');\n\n            // for treeview\n            $('ul.nav-treeview a').filter(function() {\n                return this.href == url;\n            }).parentsUntil(\".nav-sidebar > .nav-treeview\").addClass('menu-open').prev('a').addClass('active');\n\n            $(\"input[type='text']\").each(\n                function() {\n                    $(this).attr(\"autocomplete\", \"off\");\n                });\n        });\n\n        $('.close, #add_data').click(function() {\n            $('.alert-danger').fadeOut('fast');\n        });\n    </script>\n    <script>\n            window.addEventListener('close-modal', event => {\n                $('#auction-add-modal').modal('hide');\n                $('#auction-edit-modal').modal('hide');\n                $('#auction-detail-modal').modal('hide');\n                $('#auction-delete-modal').modal('hide')\n            })\n        </script>\n    <!-- Livewire Scripts -->\n\n<script src=\"/livewire/livewire.js?id=90730a3b0e7144480175\" data-turbo-eval=\"false\" data-turbolinks-eval=\"false\" ></script>\n<script data-turbo-eval=\"false\" data-turbolinks-eval=\"false\" >\n    if (window.livewire) {\n\t    console.warn('Livewire: It looks like Livewire\\'s @livewireScripts JavaScript assets have already been loaded. Make sure you aren\\'t loading them twice.')\n\t}\n\n    window.livewire = new Livewire();\n    window.livewire.devTools(true);\n    window.Livewire = window.livewire;\n    window.livewire_app_url = '';\n    window.livewire_token = '3KFJLa0HP0A1jwLhSVjiP4mIM28ucGZLcnSvmpiF';\n\n\t/* Make sure Livewire loads first. */\n\tif (window.Alpine) {\n\t    /* Defer showing the warning so it doesn't get buried under downstream errors. */\n\t    document.addEventListener(\"DOMContentLoaded\", function () {\n\t        setTimeout(function() {\n\t            console.warn(\"Livewire: It looks like AlpineJS has already been loaded. Make sure Livewire\\'s scripts are loaded before Alpine.\\\\n\\\\n Reference docs for more info: http://laravel-livewire.com/docs/alpine-js\")\n\t        })\n\t    });\n\t}\n\n\t/* Make Alpine wait until Livewire is finished rendering to do its thing. */\n    window.deferLoadingAlpine = function (callback) {\n        window.addEventListener('livewire:load', function () {\n            callback();\n        });\n    };\n\n    let started = false;\n\n    window.addEventListener('alpine:initializing', function () {\n        if (! started) {\n            window.livewire.start();\n\n            started = true;\n        }\n    });\n\n    document.addEventListener(\"DOMContentLoaded\", function () {\n        if (! started) {\n            window.livewire.start();\n\n            started = true;\n        }\n    });\n</script>\n    <script src=\"https://backoffice.ax-stg.lgq-stg.com/mask/jquery.mask.min.js\"></script>\n<script>\n    function isPublish(id) {\n        var namecheckbox = 'isPublish_' + id;\n        var checkbox = document.getElementsByName(namecheckbox);\n        for (var i = 0; i < checkbox.length; i++) {\n            if (checkbox[i].checked) {\n                livewire.emit('isPublish', id, 1)\n            } else {\n                livewire.emit('isPublish', id, 0)\n            }\n        }\n    }\n\n    function isPublishCatalog(id) {\n        var namecheckbox = 'isPublishCatalog_' + id;\n        var checkbox = document.getElementsByName(namecheckbox);\n        for (var i = 0; i < checkbox.length; i++) {\n            if (checkbox[i].checked) {\n                livewire.emit('isPublishCatalog', id, 1)\n            } else {\n                livewire.emit('isPublishCatalog', id, 0)\n            }\n        }\n    }\n\n    function isCalendar(id) {\n        var namecheckbox = 'isCalendar_' + id;\n        var checkbox = document.getElementsByName(namecheckbox);\n        for (var i = 0; i < checkbox.length; i++) {\n            if (checkbox[i].checked) {\n                livewire.emit('isCalendar', id, 1)\n            } else {\n                livewire.emit('isCalendar', id, 0)\n            }\n        }\n    }\n\n    window.addEventListener('showPublishedModal', event => {\n        $('#publish-auction-modal .published').hide();\n        $('#publish-auction-modal .unpublished').hide();\n        if (event.detail.is_publish) {\n            $('#publish-auction-modal .published').show();\n        } else {\n            $('#publish-auction-modal .unpublished').show();\n            $('[name=isPublish_' + $('#publish-auction-confirmation-modal .auctionId').val() + ']').prop('checked', false).change();\n        }\n        $('#publish-auction-modal').modal('show');\n    })\n\n    window.addEventListener('showPublishedConfirmModal', event => {\n        if (event.detail.show) {\n            $('#publish-auction-confirmation-modal').modal('show');\n        } else {\n            $('#publish-auction-confirmation-modal').modal('hide');\n        }\n    })\n\n    window.addEventListener('showPublishedCatalogModal', event => {\n        $('#publish-auction-catalog-modal .published').hide();\n        $('#publish-auction-catalog-modal .unpublished').hide();\n        if (event.detail.is_publish) {\n            $('#publish-auction-catalog-modal .published').show();\n        } else {\n            $('#publish-auction-catalog-modal .unpublished').show();\n            $('[name=isPublish_' + $('#publish-auction-confirmation-modal .auctionId').val() + ']').prop('checked', false).change();\n        }\n        $('#publish-auction-catalog-modal').modal('show');\n    })\n\n    window.addEventListener('showPublishedCatalogConfirmModal', event => {\n        if (event.detail.show) {\n            $('#publish-auction-catalog-confirmation-modal').modal('show');\n        } else {\n            $('#publish-auction-catalog-confirmation-modal').modal('hide');\n        }\n    })\n\n    $('#publish-auction-confirmation-modal').on('hidden.bs.modal', function() {\n        $('[name=isPublish_' + $('#publish-auction-confirmation-modal .auctionId').val() + ']').prop('checked', true).change();\n    });\n    $('#publish-auction-catalog-confirmation-modal').on('hidden.bs.modal', function() {\n        $('[name=isPublishCatalog_' + $('#publish-auction-catalog-confirmation-modal .auctionId').val() + ']').prop('checked', true).change();\n    });\n\n    window.addEventListener('showDeleteModal', event => {\n        if (event.detail.show) {\n            $('#auction-delete-modal').modal('show');\n        } else {\n            $('#auction-delete-modal').modal('hide');\n        }\n    })\n</script>\n</body>\n\n</html>\n"
