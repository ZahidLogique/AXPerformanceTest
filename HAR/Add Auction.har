etype');\n            font-weight: 700;\n        }\n\n        @font-face {\n            font-family: 'SukhumvitSet-Light';\n            src: url('../fonts/sukhumvit-set/SukhumvitSet-Light.ttf') format('truetype');\n            font-weight: 700; /*300*/\n        }\n\n        @font-face {\n            font-family: 'SukhumvitSet-SemiBold';\n            src: url('../fonts/sukhumvit-set/SukhumvitSet-SemiBold.ttf') format('truetype');\n            font-weight: 700; /*600*/\n        }\n\n        @font-face {\n            font-family: 'SukhumvitSet-Text';\n            src: url('../fonts/sukhumvit-set/SukhumvitSet-Text.ttf') format('truetype');\n            font-weight: 400;\n        }\n\n        @font-face {\n            font-family: 'SukhumvitSet-Thin';\n            src: url('../fonts/sukhumvit-set/SukhumvitSet-Thin.ttf') format('truetype');\n            font-weight: 100;\n        }\n        @font-face {\n            font-family: 'Ekachon';\n            src: url('/fonts/ekachon-extralight.woff') format('woff');\n            font-weight: 100;\n        }\n\n        @font-face {\n            font-family: 'Ekachon';\n            src: url('/fonts/ekachon-light.woff') format('woff');\n            font-weight: 300;\n        }\n\n        @font-face {\n            font-family: 'Ekachon';\n            src: url('/fonts/ekachon-light.woff') format('woff');\n            font-weight: 700;\n        }\n\n    </style>\n    \n        <!-- Livewire Styles -->\n<style >\n    [wire\\:loading], [wire\\:loading\\.delay], [wire\\:loading\\.inline-block], [wire\\:loading\\.inline], [wire\\:loading\\.block], [wire\\:loading\\.flex], [wire\\:loading\\.table], [wire\\:loading\\.grid], [wire\\:loading\\.inline-flex] {\n        display: none;\n    }\n\n    [wire\\:loading\\.delay\\.shortest], [wire\\:loading\\.delay\\.shorter], [wire\\:loading\\.delay\\.short], [wire\\:loading\\.delay\\.long], [wire\\:loading\\.delay\\.longer], [wire\\:loading\\.delay\\.longest] {\n        display:none;\n    }\n\n    [