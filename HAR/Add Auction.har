ts&quot;:{&quot;listeners&quot;:[&quot;isPublish&quot;,&quot;isPublishCatalog&quot;],&quot;path&quot;:&quot;https:\\/\\/backoffice.ax-stg.lgq-stg.com\\/en\\/auction-management\\/auction?auctionTable=upcoming&quot;},&quot;serverMemo&quot;:{&quot;children&quot;:[],&quot;errors&quot;:[],&quot;htmlHash&quot;:&quot;56d10560&quot;,&quot;data&quot;:{&quot;listAuction&quot;:[],&quot;auctionId&quot;:&quot;&quot;,&quot;auctionTable&quot;:&quot;upcoming&quot;,&quot;sortField&quot;:&quot;auction_date&quot;,&quot;sortAsc&quot;:false,&quot;perPage&quot;:10,&quot;page&quot;:1,&quot;search&quot;:&quot;&quot;,&quot;paginators&quot;:{&quot;page&quot;:1}},&quot;dataMeta&quot;:[],&quot;checksum&quot;:&quot;2f5df8d46cffc426d02f35fc65c408868deadbc0a341b9e75232cd0f24ee75bc&quot;}}\">\n\n    <div class=\"modal fade\" id=\"auction-delete-modal\">\n    <div class=\"modal-dialog modal-sm\">\n        <div class=\"modal-content\">\n            <div class=\"modal-header\">\n                <h4 class=\"modal-title\">Delete Auction</h4>\n                <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-label=\"Close\">\n                    <span aria-hidden=\"true\">&times;</span>\n                </button>\n            </div>\n            <div class=\"modal-body\">\n                <div class=\"row\">\n                    <div class=\"col-sm-12\">\n                        Are you sure you want to delete this data?\n                    </div>\n                </div>\n            </div>\n            <div class=\"modal-footer justify-content-between\">\n                <button type=\"button\" class=\"btn btn-default\" data-dismiss=\"modal\">Cancel</button>\n                <button class=\"btn btn-primary\" wire:click=\"deleteAuction('', true)\">Yes</button>\n            </div>\n        </div>\n    </div>\n</div>\n    <div class=\"modal fade\" id=\"publish-auction-confirmation-modal\">\n        <div class=\"modal-dialog modal-sm\">\n            <div class=\"modal-content\">\n                <div class=\"modal-header\">\n                    <h4 class=\"modal-title\">Auction Publication</h4>\n                    <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-label=\"Close\">\n                        <span aria-hidden=\"true\">&times;</span>\n                    </button>\n                </div>\n                <div class=\"modal-body\">\n                    <div class=\"row\">\n                        <div class=\"col-sm-12\">\n                            Are you sure to unpublish this auction ?\n                        </div>\n                    </div>\n                </div>\n                <div class=\"modal-footer justify-content-between\">\n                    <input type=\"hidden\" class=\"auctionId\" value=\"\" />\n                    <button type=\"button\" class=\"btn btn-default\" data-dismiss=\"modal\">Cancel</button>\n                    <button class=\"btn btn-primary\" wire:click=\"isPublish('', 0, true)\">Yes</button>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"modal fade\" id=\"publish-auction-modal\">\n        <form>\n            <div class=\"modal-dialog modal-sm\">\n                <div class=\"modal-content\">\n                    <div class=\"modal-header\">\n                        <h4 class=\"modal-title\">Auction Publication</h4>\n                        <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-label=\"Close\">\n                            <span aria-hidden=\"true\">&times;</span>\n                        </button>\n                    </div>\n                    <div class=\"modal-body\">\n                        <div class=\"row\">\n                            <div class=\"col-sm-12 published\" style=\"display:none\">\n                                Auction has been published !\n                            </div>\n                            <div class=\"col-sm-12 unpublished\" style=\"display:none\">\n                                Auction has been unpublished !\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"modal-footer justify-content-between\">\n                        <button type=\"button\" class=\"btn btn-default\" data-dismiss=\"modal\">Close</button>\n                    </div>\n                </div>\n            </div>\n        </form>\n    </div>\n\n    <div class=\"modal fade\" id=\"publish-auction-catalog-confirmation-modal\">\n        <div class=\"modal-dialog modal-sm\">\n            <div class=\"modal-content\">\n                <div class=\"modal-header\">\n                    <h4 class=\"modal-title\">Catalog Publication</h4>\n                    <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-label=\"Close\">\n                        <span aria-hidden=\"true\">&times;</span>\n                    </button>\n                </div>\n                <div class=\"modal-body\">\n                    <div class=\"row\">\n                        <div class=\"col-sm-12\">\n                            Are you sure to unpublish this auction catalog ?\n                        </div>\n                    </div>\n                </div>\n                <div class=\"modal-footer justify-content-between\">\n                    <input type=\"hidden\" class=\"auctionId\" value=\"\" />\n                    <button type=\"button\" class=\"btn btn-default\" data-dismiss=\"modal\">Cancel</button>\n                    <button class=\"btn btn-primary\" wire:click=\"isPublishCatalog('', 0, true)\">Yes</button>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"modal fade\" id=\"publish-auction-catalog-modal\">\n        <form>\n            <div class=\"modal-dialog modal-sm\">\n                <div class=\"modal-content\">\n                    <div class=\"modal-header\">\n                        <h4 class=\"modal-title\">Catalog Publication</h4>\