          tabSwitchTimeout = setTimeout(function() {\n                window.auctionDetailPending = true;\n                window.livewire.find('8E06bc3dw5kxBsIeazhr').set('activeTab', target);\n            }, 150);\n        });\n    });\n\n    // Reset flag & enable button saat request component detail selesai\n    function setInviteMemberButtonDisabled(disabled) {\n        var btn = document.getElementById('btn-invite-member');\n        if (btn) {\n            btn.disabled = !!disabled;\n        }\n    }\n    function attachAuctionDetailPendingHook() {\n        if (typeof Livewire !== 'undefined' && Livewire.hook) {\n            Livewire.hook('message.sent', function(message, component) {\n                if (component && component.fingerprint && component.fingerprint.name === 'auction-management.auction.detail') {\n                    setInviteMemberButtonDisabled(true);\n                }\n            });\n            Livewire.hook('message.received', function(message, component) {\n                if (component && component.fingerprint && component.fingerprint.name === 'auction-management.auction.detail') {\n                    window.auctionDetailPending = false;\n                    setInviteMemberButtonDisabled(false);\n                }\n            });\n        }\n    }\n    document.addEventListener('livewire:load', attachAuctionDetailPendingHook);\n    // Fallback: bila Livewire sudah di-load sebelum script ini (mis. first access / urutan load)\n    if (typeof Livewire !== 'undefined') {\n        attachAuctionDetailPendingHook();\n    }\n</script>\n</body>\n\n</html>\n"
