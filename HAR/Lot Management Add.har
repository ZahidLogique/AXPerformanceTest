rop = {\n                field: datepickerMonths[j],\n                format: 'MM/YYYY'\n            }\n            pickersMonth[j] = new Pikaday(prop)\n        }\n\n        $(document).ready(function() {\n            //load call\n            $(\".select2\").select2({\n                theme: 'bootstrap4',\n            });\n\n            //waiting emit call\n            window.livewire.on('loadSelect2', () => {\n                $(\".select2\").select2({\n                    theme: 'bootstrap4',\n                });\n            });\n\n            window.livewire.on('loadDatepicker', () => {\n                var datepickers = document.querySelectorAll(\".datepicker\");\n                // var picker = [];\n                $.each(picker, function(k, v) {\n                    v.destroy();\n                });\n                var nowYear = new Date().getFullYear();\n                var maxyear = nowYear + 5;\n\n                for (var i = 0; i < datepickers.length; i++) {\n                    let prop = {\n                        field: datepickers[i],\n                        //format: 'YYYY-MM-DD'\n                        format: 'DD/MM/YYYY',\n                        yearRange: [1968, maxyear],\n                    }\n\n                    let datepicker = $(datepickers[i]);\n                    if (datepicker.hasClass('datepicker-min-today')) {\n                        prop.minDate = new Date()\n                        console.log(prop);\n                    }\n\n                    picker[i] = new Pikaday(prop)\n                }\n            });\n\n            window.addEventListener('loadDatepicker', event => {\n                if (event.detail.id) {\n                    var datepickers = $(\"#\" + event.detail.id + \" .datepicker\");\n                    $.each(picker, function(k, v) {\n                        if ($(v._o.field).closest('#' + event.detail.id).length) {\n                            v.destroy();\n                        }\n                    });\n                } else {\n                    var datepickers = document.querySelectorAll(\".datepicker\");\n                    $.each(picker, function(k, v) {\n                        v.destroy();\n                    });\n                }\n                var nowYear = new Date().getFullYear();\n                var maxyear = nowYear + 5;\n\n                for (var i = 0; i < datepickers.length; i++) {\n                    let prop = {\n                        field: datepickers[i],\n                        //format: 'YYYY-MM-DD'\n                        format: 'DD/MM/YYYY',\n                        yearRange: [1968, maxyear],\n                    }\n\n                    let datepicker = $(datepickers[i]);\n                    if (datepicker.hasClass('datepicker-min-today')) {\n                        prop.minDate = new Date()\n                        console.log(prop);\n                    }\n\n                    picker[i] = new Pikaday(prop)\n                }\n            })\n\n            window.addEventListener('swalError', event => {\n                Swal.fire({\n                    icon: 'error',\n                    title: 'Error',\n                    text: event.detail.messages\n                })\n            })\n\n            window.addEventListener('loadCurrencyMasking', event => {\n                $('.input-currency').mask(\"#,##0\", {\n                    reverse: true\n                });\n            })\n\n            $(\".upper_text\").keyup(function() {\n                var valtext = $(this).val()\n                $(this).val(valtext.toUpperCase())\n            });\n\n            $(\".timepicker\").flatpickr({\n                enableTime: true,\n                noCalendar: true,\n                dateFormat: \"H:i\",\n                time_24hr: true\n            });\n        });\n\n        function numberToCurrency(a) {\n            if (a != '' && a != null) {\n                a = a.toString();\n                var b = a.replace(/[^\\d\\.]/g, '');\n                var dump = b.split('.');\n                var c = '';\n                var lengthchar = dump[0].length;\n                var j = 0;\n                for (var i = lengthchar; i > 0; i--) {\n                    j = j + 1;\n                    if (((j % 3) == 1) && (j != 1)) {\n                        c = dump[0].substr(i - 1, 1) + ',' + c;\n                    } else {\n                        c = dump[0].substr(i - 1, 1) + c;\n                    }\n                }\n\n                if (dump.length > 1) {\n                    if (dump[1].length > 0) {\n                        c += '.' + dump[1];\n                    } else {\n                        c += '.';\n                    }\n                }\n                return c;\n            } else {\n                return '';\n            }\n        }\n\n        $(document).ready(function() {\n            window.livewire.on('alert_remove', () => {\n                setTimeout(function() {\n                    $('.alert-success').fadeOut('fast');\n                }, 5000); // 5 secs\n            });\n\n            /** add active class and stay opened when selected */\n            var url = window.location;\n\n            // for sidebar menu entirely but not cover treeview\n            $('ul.nav-sidebar a').filter(function() {\n                return this.href == url;\n            }).addClass('active');\n\n            // for treeview\n            $('ul.nav-treeview a').filter(function() {\n                return this.href == url;\n            }).parentsUntil(\".nav-sidebar > .nav-treeview\").addClass('menu-open').prev('a').addClass('active');\n\n            $(\"input[type='text']\").each(\n                function() {\n                    $(this).attr(\"autocomplete\", \"off\");\n                });\n        });\n\n        $('.close, #add_data').click(function() {\n            $('.alert-danger').fadeOut('fast');\n        });\n    </script>\n    <script>\n        window.addEventListener('close