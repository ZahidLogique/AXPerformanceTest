          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert Bidding Validation - HTTP 200">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Bidding Validation GAGAL - token expired atau user tidak berhak bid</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">8</intProp>
          </ResponseAssertion>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Override CURRENT_PRICE from Bidding Validation" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def responseBody = prev.getResponseDataAsString()
log.info("=== Bidding Validation (Iter " + vars.get("CURRENT_LOOP") + ") ===")
log.info(responseBody)

def json = new JsonSlurper().parseText(responseBody)
def data = json.data

// PARENT_BID_ID sudah di-set dari check-latest (2h), tidak di-override di sini
// Override CURRENT_PRICE dari next_price (server authoritative)
def nextPrice = data?.next_price
if (nextPrice != null &amp;&amp; nextPrice instanceof Number &amp;&amp; (nextPrice as int) > 0) {
    vars.put("CURRENT_PRICE", (nextPrice as int).toString())
    log.info("CURRENT_PRICE overridden by next_price: " + nextPrice)
} else {
    log.info("next_price tidak tersedia, CURRENT_PRICE tetap dari check-latest: " + vars.get("CURRENT_PRICE"))
}

log.info("=== Bid akan dikirim (Iter " + vars.get("CURRENT_LOOP") + ") ===")
log.info("current_price: " + vars.get("CURRENT_PRICE"))
def cp = vars.get("CURRENT_PRICE") as int
def inc = vars.get("INCREMENT") as int
log.info("last_price (bid): " + (cp + inc))
log.info("parent_bid_id: " + vars.get("PARENT_BID_ID"))
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- STEP 2j-fresh: GET Fresh Price (pre-bid) -->
