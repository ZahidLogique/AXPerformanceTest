          </elementProp>
          <!-- AUCTION_DATE / MONTH / YEAR: digunakan di Phase 1 schedule & catalog -->
          <elementProp name="AUCTION_DATE" elementType="Argument">
            <stringProp name="Argument.name">AUCTION_DATE</stringProp>
            <stringProp name="Argument.value">2026-04-28</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="AUCTION_MONTH" elementType="Argument">
            <stringProp name="Argument.name">AUCTION_MONTH</stringProp>
            <stringProp name="Argument.value">4</stringProp>
