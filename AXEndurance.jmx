                  <boolProp name="HTTPArgument.use_equals">true</boolProp>
                </elementProp>
              </collectionProp>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree/>

          <!-- 1c. Get reminder list -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="1c. GET Remind Me List" enabled="true">
            <stringProp name="HTTPSampler.domain">${BASE_URL}</stringProp>
