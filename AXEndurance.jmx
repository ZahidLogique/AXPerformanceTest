            <!-- Extract CUSTOMER_NAME dari /membership/me response -->
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract CUSTOMER_NAME from /me" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
import groovy.json.JsonSlurper
def body = prev.getResponseDataAsString()
try {
    def json = new JsonSlurper().parseText(body)
    def data = json.data
    if (data?.full_name) {
        vars.put("CUSTOMER_NAME", data.full_name as String)
        vars.put("CUSTOMER_EMAIL", data.email as String ?: vars.get("USERNAME"))
        log.info("[Phase1] CUSTOMER_NAME: " + data.full_name + " | EMAIL: " + data.email)
    }
} catch (Exception e) {
    log.warn("[Phase1] Gagal parse /membership/me: " + e.getMessage())
}
              </stringProp>
            </JSR223PostProcessor>
