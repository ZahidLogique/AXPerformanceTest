          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract bid state from check-latest (authoritative)" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def body = prev.getResponseDataAsString()
log.info("=== check-latest Response (Iter " + vars.get("CURRENT_LOOP") + ") ===")
log.info(body)

if (!body.startsWith("432")) {
    log.warn("check-latest: dapat non-ACK message, skip parsing. body=" + body.take(80))
    return
}

def jsonStr = body.replaceFirst('^\\d+', '')
def arr = new JsonSlurper().parseText(jsonStr)
def obj = arr[0]

if (!(obj instanceof Map) || obj?.data == null) {
    log.warn("check-latest: format tidak dikenali atau data null! body=" + body)
    return
}

def data = obj.data
def eventId   = data._id as String
def lastPrice = data.last_price as int
def nextPrice = data.next_price

vars.put("PARENT_BID_ID", eventId)
vars.put("CURRENT_PRICE", lastPrice.toString())

log.info("=== Bid state dari check-latest (Iter " + vars.get("CURRENT_LOOP") + ") ===")
log.info("PARENT_BID_ID: " + eventId)
log.info("CURRENT_PRICE: " + lastPrice)
log.info("next_price (info): " + nextPrice)
log.info("BID akan dikirim: " + (lastPrice + (vars.get("INCREMENT") as int)))
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

