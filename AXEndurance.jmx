          <elementProp name="CUSTOMER_EMAIL" elementType="Argument">
            <stringProp name="Argument.name">CUSTOMER_EMAIL</stringProp>
            <stringProp name="Argument.value"></stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="CUSTOMER_PHONE" elementType="Argument">
            <stringProp name="Argument.name">CUSTOMER_PHONE</stringProp>
            <stringProp name="Argument.value">66123123123</stringProp>
