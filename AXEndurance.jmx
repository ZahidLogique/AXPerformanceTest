        <hashTree>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Refresh CURRENT_PRICE from fresh history-bid" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper

def responseBody = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(responseBody)
def data = json.data

def firstBid = data.find { it.last_price != null &amp;&amp; it.last_price instanceof Number }

if (firstBid) {
    def freshPrice = firstBid.last_price as int
    def oldPrice = vars.get("CURRENT_PRICE")
    vars.put("CURRENT_PRICE", freshPrice.toString())
    log.info("=== Fresh Price (Iter " + vars.get("CURRENT_LOOP") + ") ===")
    log.info("CURRENT_PRICE updated: " + oldPrice + " -> " + freshPrice)
    log.info("BID akan dikirim: " + (freshPrice + (vars.get("INCREMENT") as int)))
} else {
    log.warn("2j-fresh: tidak ada entry valid, CURRENT_PRICE tetap: " + vars.get("CURRENT_PRICE"))
}
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!--  STEP 2k: Kirim bid via WebSocket (423)                           -->
        <!--  current_price = last_price dari check-latest                    -->
        <!--  last_price    = current_price + increment                        -->
        <!--  parent_bid_id = _id dari check-latest (langsung, tanpa -2)      -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleWriteWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler" testname="2k. WebSocket Write - Customer Bid (423)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="dataType">Text</stringProp>
          <stringProp name="requestData">423["customer-bidding",{"headers":{"headers":{"Authorization":"Bearer ${TOKEN}","lang":"en"}},"payload":{"auction_id":"${AUCTION_ID}","auction_lane":"${AUCTION_LANE}","room_id":"${ROOM_ID}","auction_lot":"${AUCTION_LOT}","bidtype":"web","nipl":"${NIPL}","increment":${INCREMENT},"reserved_price":0,"inventory_id":"${INVENTORY_ID}","current_price":${CURRENT_PRICE},"last_price":${__intSum(${CURRENT_PRICE},${INCREMENT},)},"parent_bid_id":"${PARENT_BID_ID}","seller_id":"${SELLER_ID}"}}]</stringProp>
        </eu.luminis.jmeter.wssampler.SingleWriteWebSocketSampler>
        <hashTree/>

        <!-- STEP 2l: Broadcast 1 — bid-lock (optional) -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2l. WebSocket Read - Broadcast 1 (bid-lock)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">5000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree/>

        <!-- STEP 2m: Broadcast 2 — bidding info -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2m. WebSocket Read - Broadcast 2 (bidding)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">5000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree/>

        <!-- STEP 2n: Broadcast 3 — bid-unlock -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2n. WebSocket Read - Broadcast 3 (bid-unlock)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">5000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree/>

        <!-- STEP 2o: Baca Bid ACK (433) -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2o. WebSocket Read - Bid ACK (433)" enabled="true">
          <boolProp name="TLS">false</boolProp>
          <stringProp name="server"></stringProp>
          <stringProp name="port">80</stringProp>
          <stringProp name="path"></stringProp>
          <stringProp name="connectTimeout">20000</stringProp>
          <stringProp name="dataType">Text</stringProp>
          <boolProp name="createNewConnection">false</boolProp>
          <stringProp name="readTimeout">8000</stringProp>
          <boolProp name="optional">true</boolProp>
        </eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert Bid ACK - status:true" enabled="false">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="49586">status&quot;:true</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Bid ACK tidak mengandung status:true</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">true</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

        <!-- STEP 2p: Baca countdown broadcast -->
        <eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler guiclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSamplerGui" testclass="eu.luminis.jmeter.wssampler.SingleReadWebSocketSampler" testname="2p. WebSocket Read - Countdown broadcast" enabled="true">
