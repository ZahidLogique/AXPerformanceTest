          </elementProp>
          <elementProp name="AUCTION_ID" elementType="Argument">
            <stringProp name="Argument.name">AUCTION_ID</stringProp>
            <stringProp name="Argument.value">c2aa752c-71df-4685-919c-001e4b5668c0</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="INVENTORY_ID" elementType="Argument">
            <stringProp name="Argument.name">INVENTORY_ID</stringProp>
            <stringProp name="Argument.value">46133def-fe4b-4416-9b57-82a7d3fa3be5</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="AUCTION_LANE" elementType="Argument">
