            <stringProp name="RegexExtractor.regex">&amp;quot;auction_car_id&amp;quot;:&amp;quot;([a-f0-9\-]{36})&amp;quot;</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
