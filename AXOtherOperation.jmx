          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Store Session as Property" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def cookieMgr = sampler.getCookieManager()
def sessionFound = false
def xsrfFound = false
for (int i = 0; i &lt; cookieMgr.getCookieCount(); i++) {
    def cookie = cookieMgr.get(i)
    log.info("POST cookie found: " + cookie.getName())
    if (cookie.getName() == "auction_express_session") {
        props.put("ADMIN_SESSION", cookie.getValue())
        log.info("Admin session stored: " + cookie.getValue().take(20) + "...")
        sessionFound = true
    }
    if (cookie.getName() == "XSRF-TOKEN") {
        def rawXsrf = cookie.getValue()
        props.put("ADMIN_XSRF", rawXsrf)
        props.put("ADMIN_XSRF_DECODED", java.net.URLDecoder.decode(rawXsrf, "UTF-8"))
        log.info("XSRF stored (POST): " + rawXsrf.take(20) + "...")
        xsrfFound = true
    }
}
if (!sessionFound) log.error("Failed to extract admin session from CookieManager!")
if (!xsrfFound) log.warn("XSRF-TOKEN not found after POST login")
props.put("ADMIN_LOGIN_TIME", System.currentTimeMillis())
            </stringProp>
          </JSR223PostProcessor>
