            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import groovy.json.JsonSlurper
def body = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(body)
def token = json?.access_token
if (token) {
    props.put("ADMIN_TOKEN", "Bearer " + token)
    log.info("ADMIN_TOKEN stored: Bearer " + token.take(20) + "...")
} else {
    log.error("Failed to extract API token. Response: " + body.take(200))
}
