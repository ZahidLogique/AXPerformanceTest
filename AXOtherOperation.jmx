          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log auction_car_id" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">
def carId = vars.get("AUCTION_CAR_ID")
log.info("Extracted auction_car_id: " + carId)
// Simpan 2000 chars dari body show-payment untuk cek context auction_car_id
def body = prev.getResponseDataAsString()
def idx = body.indexOf(carId ?: "NOT_FOUND")
if (idx >= 0) {
    def ctx = body.substring(Math.max(0, idx - 200), Math.min(body.length(), idx + 200))
    log.info("Context around auction_car_id in show-payment: " + ctx)
}
// Save full body portion near auction_car_id to file
def f = new File("C:/JMeter/AX/show_payment_debug.txt")
f.text = "AUCTION_CAR_ID: " + carId + "\nContext:\n" + (idx >= 0 ? body.substring(Math.max(0, idx-300), Math.min(body.length(), idx+300)) : "NOT FOUND")
// Set LIST_PAYMENT_BILL_JSON
def billJson = '[{"auction_car_id":"' + carId + '","sold_price":"100000","sold_price_vat":"7000","service_fee":"25600","service_fee_vat":"1792","service_fee_wht":"768","net_seller_fee":0,"net_seller_fee_vat":0,"net_seller_fee_wht":0,"sold_price_10":"10700","total_amount_vehicle":107000,"total_amount_fee":26624,"receive_amount_vehicle":0,"receive_amount_fee":20000,"list_sort_number":[1]}]'
vars.put("LIST_PAYMENT_BILL_JSON", billJson)
            </stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
        </hashTree>
