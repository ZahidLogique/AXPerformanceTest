          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Debug Submit Response" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">
def code = prev.getResponseCode()
def body = prev.getResponseDataAsString()
def carId = vars.get("AUCTION_CAR_ID")
log.info("Submit Payment response code: " + code + " | AUCTION_CAR_ID=" + carId)
// Tulis response ke file untuk debug
def f = new File("C:/JMeter/AX/payment_response_debug.txt")
// Get raw request body (postBodyRaw=true maka argument pertama adalah body)
def reqBody = ""
try {
    reqBody = sampler.getArguments().getArgument(0).getValue()
} catch (Exception e) {
    reqBody = "ERROR reading request body: " + e.getMessage()
}
f.text = "CODE: " + code + "\nAUCTION_CAR_ID var: " + carId + "\n\nREQUEST BODY:\n" + reqBody + "\n\nRESPONSE BODY:\n" + body
log.info("Submit Payment debug saved")
            </stringProp>
