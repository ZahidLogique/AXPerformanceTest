        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Re-login Admin Backoffice" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">import org.apache.http.impl.client.HttpClients
import org.apache.http.impl.client.BasicCookieStore
import org.apache.http.client.methods.HttpGet
import org.apache.http.client.methods.HttpPost
import org.apache.http.entity.StringEntity
import org.apache.http.conn.ssl.NoopHostnameVerifier
import org.apache.http.conn.ssl.SSLConnectionSocketFactory
import org.apache.http.ssl.SSLContextBuilder
import org.apache.http.ssl.TrustStrategy
import java.security.cert.X509Certificate

def ts = new TrustStrategy() {
    boolean isTrusted(X509Certificate[] chain, String authType) { return true }
}
def sslCtx = SSLContextBuilder.create().loadTrustMaterial(null, ts).build()
def sslsf = new SSLConnectionSocketFactory(sslCtx, NoopHostnameVerifier.INSTANCE)
def cookieStore = new BasicCookieStore()
def client = HttpClients.custom().setSSLSocketFactory(sslsf).setDefaultCookieStore(cookieStore).build()
def base = "https://backoffice.ax-stg.lgq-stg.com"
try {
    def get = new HttpGet(base + "/")
    get.setHeader("User-Agent", "Mozilla/5.0")
    def resp1 = client.execute(get)
    def body1 = resp1.entity.content.text
    resp1.close()
    def m = (body1 =~ /name="_token"\s+value="([^"]+)"/)
    if (!m) { log.error("Re-login: CSRF not found"); return }
    def csrf = m[0][1]
    def postData = "_token=" + URLEncoder.encode(csrf, "UTF-8") + "&amp;username=admin&amp;password=" + URLEncoder.encode("Qwer1234!", "UTF-8") + "&amp;language=en"
    def post = new HttpPost(base + "/")
    post.setHeader("Content-Type", "application/x-www-form-urlencoded")
    post.setHeader("User-Agent", "Mozilla/5.0")
    post.setEntity(new StringEntity(postData))
    def resp2 = client.execute(post)
    resp2.close()
    def newSession = null
    def newXsrf = null
    for (c in cookieStore.getCookies()) {
        if (c.getName() == "auction_express_session") newSession = c.getValue()
        if (c.getName() == "XSRF-TOKEN") newXsrf = c.getValue()
    }
    if (newSession) { props.put("ADMIN_SESSION", newSession); log.info("Re-login: ADMIN_SESSION refreshed") }
    else { log.error("Re-login: session not found in response") }
    if (newXsrf) { props.put("ADMIN_XSRF", newXsrf); props.put("ADMIN_XSRF_DECODED", URLDecoder.decode(newXsrf, "UTF-8")) }
    props.put("ADMIN_LOGIN_TIME", System.currentTimeMillis())
    log.info("Admin re-login complete at: " + new Date())
} finally { client.close() }
            </stringProp>
          </JSR223Sampler>
