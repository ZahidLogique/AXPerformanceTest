          <stringProp name="IfController.condition">${__jexl3((System.currentTimeMillis() - props.getLong("ADMIN_LOGIN_TIME", 0)) &gt; 420000)}</stringProp>
          <boolProp name="IfController.evaluateAll">false</boolProp>
